# API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_API_KEY

# Model ID (required)
MODEL_ID= YOUR_MODEL

# Base URL (optional, for Anthropic-compatible providers)
ANTHROPIC_BASE_URL= YOUR_BASE_URL

# Background task settings (optional)
BACKGROUND_TASK_OUTPUT_DIR=.task_outputs
BACKGROUND_TASK_MAX_POOL_SIZE=4
BACKGROUND_TASK_CLEANUP_HOURS=1